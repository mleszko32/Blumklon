<script>
    // --- AKORDEONY UI ---
    function toggleRightAcc(el) {
        let content = el.nextElementSibling;
        let isActive = el.classList.contains('active');
        if (isActive) { el.classList.remove('active'); content.classList.remove('active'); } 
        else { el.classList.add('active'); content.classList.add('active'); }
    }

    // --- ZMIANA ZAKŁADEK GŁÓWNYCH ---
    function switchMainTab(tabId) {
        document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
        document.getElementById('btn-' + tabId).classList.add('active');
        
        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
        document.getElementById('tab-' + tabId).classList.add('active');

        document.querySelectorAll('.sub-tools').forEach(t => t.style.display = 'none');
        let subTool = document.getElementById('sub-tools-' + tabId);
        if(subTool) subTool.style.display = 'block';
    }

    function focusFrontFormula() {
        document.getElementById('front_formula').focus();
        document.getElementById('front_formula').select();
    }

    // --- KALKULATOR GŁĘBOKOŚCI CAŁKOWITEJ/BOKU ---
    function updateDepth(source) {
        let tFront = parseFloat(document.getElementById('front_t').value) || 18;
        let tPlecy = parseFloat(document.getElementById('back_t').value) || 3;
        let backType = document.getElementById('back_type').value;

        // Ile dodajemy do płyty boku, żeby uzyskać wymiar całej wnęki ze ścianą
        let extraDepth = tFront;
        if (backType === 'nakladane') {
            extraDepth += tPlecy;
        }

        if (source === 'bok') {
            let dBox = parseFloat(document.getElementById('cab_d').value) || 510;
            document.getElementById('cab_total_d').value = dBox + extraDepth;
        } 
        else if (source === 'total') {
            let total = parseFloat(document.getElementById('cab_total_d').value) || 528;
            document.getElementById('cab_d').value = total - extraDepth;
        }
        
        // Zawsze na koniec przeliczamy i aktualizujemy model 3D
        updateState();
    }

    // --- PARSER WZORU BLUM (TOP-DOWN) ---
    function parseBlumFormula(formulaStr, totalSpace, gapSize) {
        if (!formulaStr) return [];
        let s = formulaStr.replace(/\s+/g, '').toLowerCase();

        // 1. Równe podziały (np. "3")
        if (/^\d+$/.test(s)) {
            let c = parseInt(s);
            if (c > 0 && c <= 15) return Array(c).fill((totalSpace - (c - 1) * gapSize) / c);
        }

        // 2. Proporcje (np. "1:2:2")
        if (s.includes(':')) {
            let p = s.split(':').map(Number);
            if (p.every(n => !isNaN(n) && n > 0)) {
                let sum = p.reduce((a, b) => a + b, 0);
                let avail = totalSpace - (p.length - 1) * gapSize;
                return p.map(n => avail * (n / sum));
            }
        }

        // 3. Wartości stałe i gwiazdka (np. "140;*;200")
        let splitReg = /[,;+]/;
        if (splitReg.test(s) || s.includes('*')) {
            let tokens = s.split(splitReg);
            if(tokens.length === 1 && s.includes('*')) tokens = s.split('*').map(t => t === '' ? '*' : t); 
            
            let fixedSum = 0; let starCount = 0; let valid = true;
            tokens.forEach(t => {
                if (t === '*') starCount++;
                else { let v = parseFloat(t); if (isNaN(v) || v <= 0) valid = false; else fixedSum += v; }
            });

            if (valid && tokens.length > 0) {
                let avail = totalSpace - (tokens.length - 1) * gapSize;
                let rem = avail - fixedSum;
                let starVal = starCount > 0 ? Math.max(10, rem / starCount) : 0; 
                return tokens.map(t => t === '*' ? starVal : parseFloat(t));
            }
        }
        return [];
    }

    // --- GLOBALNY STAN KORPUSU ---
    let cabinetState = {
        box: { h: 720, w: 600, d: 510, t: 18 },
        gaps: { t: 8, b: 0, l: 2, r: 2, f: 3 },
        fronts: { t: 18, overlay: 'nakladany', formula: '3', output: [] }
    };

    function updateState() {
        let s = cabinetState;
        
        // Zczytanie danych korpusu
        s.box.h = parseFloat(document.getElementById('cab_h').value) || 720;
        s.box.w = parseFloat(document.getElementById('cab_w').value) || 600;
        s.box.d = parseFloat(document.getElementById('cab_d').value) || 510;
        s.box.t = parseFloat(document.getElementById('cab_t').value) || 18;
        
        // Zczytanie szczelin
        s.gaps.t = parseFloat(document.getElementById('gap_t').value) || 0;
        s.gaps.b = parseFloat(document.getElementById('gap_b').value) || 0;
        s.gaps.l = parseFloat(document.getElementById('gap_l').value) || 0;
        s.gaps.r = parseFloat(document.getElementById('gap_r').value) || 0;
        s.gaps.f = parseFloat(document.getElementById('gap_f').value) || 0;

        // Wymiary wewnętrzne
        let wewH = s.box.h - (s.box.t * 2);
        let wewW = s.box.w - (s.box.t * 2);
        let backType = document.getElementById('back_type').value;
        let wewD = s.box.d - (backType === 'nut' ? 15 : 0); // Odejmujemy 15mm na nut, przy nakładanych wnętrze = cały bok
        
        document.getElementById('in_h').innerText = wewH;
        document.getElementById('in_w').innerText = wewW;
        document.getElementById('in_d').innerText = wewD;

        // Zczytanie Frontów
        s.fronts.t = parseFloat(document.getElementById('front_t').value) || 18;
        s.fronts.overlay = document.getElementById('front_overlay').value;
        s.fronts.formula = document.getElementById('front_formula').value;

        // Przeliczenie podziału frontów (TOP-DOWN)
        let totalFrontSpaceH = s.box.h - s.gaps.t - s.gaps.b;
        if (s.fronts.overlay === 'wpuszczany') {
            totalFrontSpaceH = s.box.h - (2 * s.box.t) - s.gaps.t - s.gaps.b;
        }
        
        s.fronts.output = parseBlumFormula(s.fronts.formula, totalFrontSpaceH, s.gaps.f);

        // Wygenerowanie listy frontów w HTML
        let listHtml = '';
        let frontW = s.box.w - s.gaps.l - s.gaps.r;
        if (s.fronts.overlay === 'wpuszczany') frontW = s.box.w - (2 * s.box.t) - s.gaps.l - s.gaps.r;

        if(s.fronts.output && s.fronts.output.length > 0) {
            s.fronts.output.forEach((h, index) => {
                let blumNum = s.fronts.output.length - index;
                listHtml += `
                <div class="front-list-item">
                    <span class="name">› A/${blumNum} Front</span>
                    <span class="dim">${h.toFixed(1)} x ${frontW.toFixed(1)} mm</span>
                </div>`;
            });
        } else {
            listHtml = `<div style="padding: 15px 20px; color:#d32f2f; font-size:0.85rem; font-weight:bold; background:#fff;">Błędna formuła (np. użyj 3 lub 140;*;200)</div>`;
        }
        document.getElementById('fronts-list-container').innerHTML = listHtml;

        // Odświeżenie widoku 3D
        render3D();
    }

    // --- SILNIK 3D (Three.js) ---
    let scene, camera, renderer, group, controls;

    function init3D() {
        let container = document.getElementById('canvas-container');
        scene = new THREE.Scene();
        scene.background = new THREE.Color(0xe8ebed);
        
        camera = new THREE.PerspectiveCamera(40, container.clientWidth / container.clientHeight, 1, 10000);
        camera.position.set(800, 1000, 1800);
        
        renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(container.clientWidth, container.clientHeight);
        container.appendChild(renderer.domElement);
        
        controls = new THREE.OrbitControls(camera, renderer.domElement);
        controls.target.set(0, 400, 0);
        controls.enableDamping = true;
        
        scene.add(new THREE.AmbientLight(0xffffff, 0.8));
        let dirLight = new THREE.DirectionalLight(0xffffff, 0.4);
        dirLight.position.set(500, 1000, 800);
        scene.add(dirLight);

        scene.add(new THREE.GridHelper(2000, 40, 0xcccccc, 0xdddddd));
        group = new THREE.Group();
        scene.add(group);

        animate();
        window.addEventListener('resize', () => {
            renderer.setSize(container.clientWidth, container.clientHeight);
            camera.aspect = container.clientWidth / container.clientHeight;
            camera.updateProjectionMatrix();
        });
    }

    function animate() {
        requestAnimationFrame(animate);
        controls.update();
        renderer.render(scene, camera);
    }

    function addBoard(w, h, d, x, y, z, mat, edgeMat) {
        let geom = new THREE.BoxGeometry(w, Math.max(h, 0.1), Math.max(d, 0.1));
        let mesh = new THREE.Mesh(geom, mat);
        let edges = new THREE.EdgesGeometry(geom);
        mesh.add(new THREE.LineSegments(edges, edgeMat));
        mesh.position.set(x, y, z);
        group.add(mesh);
    }

    function render3D() {
        if (!group) return;
        while(group.children.length > 0) group.remove(group.children[0]); 

        let s = cabinetState;
        
        const matBoard = new THREE.MeshLambertMaterial({ color: 0xe3d6c1 }); 
        const matEdge = new THREE.LineBasicMaterial({ color: 0x9e8a6a, linewidth: 1 });
        const matFront = new THREE.MeshLambertMaterial({ color: 0x6184d8, transparent: true, opacity: 0.75 });

        // --- BOKI KORPUSU ---
        let sideH = s.box.h;
        addBoard(s.box.t, sideH, s.box.d, -s.box.w/2 + s.box.t/2, sideH/2, s.box.d/2, matBoard, matEdge); 
        addBoard(s.box.t, sideH, s.box.d, s.box.w/2 - s.box.t/2, sideH/2, s.box.d/2, matBoard, matEdge);

        // --- WIEŃCE KORPUSU ---
        let wienW = s.box.w - 2*s.box.t;
        addBoard(wienW, s.box.t, s.box.d, 0, s.box.t/2, s.box.d/2, matBoard, matEdge); // Dół
        addBoard(wienW, s.box.t, s.box.d, 0, s.box.h - s.box.t/2, s.box.d/2, matBoard, matEdge); // Góra

        // --- FRONTY ---
        if (s.fronts.output && s.fronts.output.length > 0) {
            let frontW = s.box.w - s.gaps.l - s.gaps.r;
            let frontX = 0 + (s.gaps.l / 2) - (s.gaps.r / 2); 
            let frontZ = s.box.d + (s.fronts.t / 2) + 1; 
            let currentTopY = s.box.h - s.gaps.t;

            if (s.fronts.overlay === 'wpuszczany') {
                frontW = s.box.w - (2 * s.box.t) - s.gaps.l - s.gaps.r;
                frontX = 0; 
                frontZ = s.box.d - (s.fronts.t / 2);
                currentTopY = s.box.h - s.box.t - s.gaps.t;
            }

            s.fronts.output.forEach(fh => {
                let frontY = currentTopY - (fh / 2);
                addBoard(frontW, fh, s.fronts.t, frontX, frontY, frontZ, matFront, matEdge);
                currentTopY -= (fh + s.gaps.f); 
            });
        }
    }

    // START
    window.onload = () => {
        init3D();
        updateDepth('bok'); // Ustawia poprawne dane całkowite na start i wymusza updateState()
    };
</script>
